{
  "name": "chatzoomcontrols",
  "displayName": "Chat Zoom Controls",
  "description": "Quickly zoom AI chat text and code blocks by adjusting their font sizes in sync.",
  "version": "0.0.9",
  "publisher": "goohan",
  "license": "MIT",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "chat",
    "font size",
    "zoom",
    "accessibility",
    "copilot",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/goohan/chatzoomcontrols.git"
  },
  "bugs": {
    "url": "https://github.com/goohan/chatzoomcontrols/issues"
  },
  "homepage": "https://github.com/goohan/chatzoomcontrols#readme",
  "main": "./extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "chatzoomcontrols.increase",
        "title": "Increase Chat Zoom",
        "category": "Chat Zoom"
      },
      {
        "command": "chatzoomcontrols.decrease",
        "title": "Decrease Chat Zoom",
        "category": "Chat Zoom"
      },
      {
        "command": "chatzoomcontrols.reset",
        "title": "Reset Chat Zoom",
        "category": "Chat Zoom"
      }
    ],
    "keybindings": [
      {
        "command": "chatzoomcontrols.increase",
        "key": "ctrl+alt+numpad_add",
        "mac": "cmd+alt+numpad_add"
      },
      {
        "command": "chatzoomcontrols.decrease",
        "key": "ctrl+alt+numpad_subtract",
        "mac": "cmd+alt+numpad_subtract"
      },
      {
        "command": "chatzoomcontrols.reset",
        "key": "ctrl+alt+numpad_multiply",
        "mac": "cmd+alt+numpad_multiply"
      }
    ],
    "configuration": {
      "title": "Chat Zoom Controls",
      "properties": {
        "chatZoomControls.minimum": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "description": "Minimum Markdown font size allowed by the decrease command."
        },
        "chatZoomControls.maximum": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "description": "Maximum Markdown font size allowed by the increase command."
        },
        "chatZoomControls.step": {
          "type": "number",
          "default": 1,
          "exclusiveMinimum": 0,
          "description": "Amount added or subtracted by each command."
        },
        "chatZoomControls.resetValue": {
          "type": "number",
          "default": 13,
          "minimum": 1,
          "description": "Markdown font size applied by the reset command."
        },
        "chatZoomControls.codeBlockOffset": {
          "type": "number",
          "default": 1,
          "description": "Value added to the Markdown font size for chat code blocks."
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "test": "node --test",
    "check": "npm run lint && npm test",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@vscode/vsce": "^3.6.0",
    "eslint": "^9.31.0",
    "globals": "^16.3.0"
  }
}
